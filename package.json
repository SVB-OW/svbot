{
	"name": "svbot",
	"version": "1.2.0",
	"license": "MIT",
	"scripts": {
		"start": "node out/main.js",
		"build": "npx -p typescript tsc",
		"dev": "npx concurrently --raw \"tsc --watch\" \"npx nodemon out/main.js\"",
		"deploy": "yarn build && node deploy.mjs",
		"lint": "eslint src/",
		"lint-fix": "eslint src/ --fix",
		"format": "prettier --check \"src/**/*.{ts,js}\"",
		"format-fix": "prettier --write \"src/**/*.{ts,js}\"",
		"test": "jest",
		"test:watch": "jest --watch"
	},
	"dependencies": {
		"@discordjs/rest": "^1.5.0",
		"discord.js": "^14.7.1",
		"dotenv": "^16.0.3",
		"fuse.js": "^6.6.2",
		"mongodb": "^5.1.0",
		"sendmail": "^1.6.1",
		"typescript": "^4.9.5"
	},
	"devDependencies": {
		"@typescript-eslint/eslint-plugin": "^5.38.1",
		"@typescript-eslint/parser": "^5.38.1",
		"@types/jest": "^29.2.0",
		"@types/node": "^18.11.7",
		"eslint": "^8.24.0",
		"prettier": "^2.7.1",
		"jest": "^29.2.2",
		"ts-jest": "^29.0.3",
		"ts-node": "^10.9.1"
	}
}
