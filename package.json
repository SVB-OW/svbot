{
	"name": "svbot",
	"version": "1.2.0",
	"license": "MIT",
	"scripts": {
		"start": "node out/main.js",
		"build": "npx -p typescript tsc",
		"dev": "npx concurrently --raw \"tsc --watch\" \"npx nodemon out/main.js\"",
		"deploy": "yarn build && node deploy.mjs",
		"lint": "eslint src/",
		"lint-fix": "eslint src/ --fix",
		"format": "prettier --check \"src/**/*.{ts,js}\"",
		"format-fix": "prettier --write \"src/**/*.{ts,js}\"",
		"test": "vitest run",
		"test:watch": "vitest watch"
	},
	"dependencies": {
		"discord.js": "^14.7.1",
		"dotenv": "^16.0.3",
		"fuse.js": "^6.6.2",
		"mongodb": "^5.1.0",
		"sendmail": "^1.6.1",
		"typescript": "^5.3.3"
	},
	"devDependencies": {
		"@types/node": "^18.11.7",
		"@typescript-eslint/eslint-plugin": "^5.38.1",
		"@typescript-eslint/parser": "^5.38.1",
		"eslint": "^8.34.0",
		"mongodb-memory-server": "^9.1.6",
		"prettier": "^2.8.4",
		"ts-node": "^10.9.1",
		"vitest": "^1.3.0"
	}
}
